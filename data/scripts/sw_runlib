##############################   RUN VULKAN   ##################################

create_backup() {

    if [ "${SW_USE_BACKUP_UPDATE_PERIOD}" != 0 ]; then

        export SOURCE_DIR="${START_WINE_PATH}/data/app_saves"
        export FULL_BACKUP_FILE="${START_WINE_PATH}/data/pfx_backup/saves_backup.iso"

        if [ ! -f "${FULL_BACKUP_FILE}" ] || [ -z "$(find "${FULL_BACKUP_FILE}" -mtime -${SW_USE_BACKUP_UPDATE_PERIOD} 2>/dev/null)" ]; then
            try_remove "$SOURCE_DIR/${USER}"
            print_info "Updating the backup image..."

            if mksquashfs "${SOURCE_DIR}" "${FULL_BACKUP_FILE}" -noappend -b 1M -comp zstd -Xcompression-level 1 2>/dev/null; then
                print_info "Backup updated successfully"
            else
                print_error "Error updating backup!"
            fi
        fi
    fi

}

RUN_VULKAN () {

    if [ "${SW_USE_OPENGL}" == "1" ]; then

        try_fix_pfx

        sw_win_ver

        try_link_d3d_plugins

        unset VK_INSTANCE_LAYERS VK_LOADER_LAYERS_ENABLE

        for wine_build_dll in d3d12 d3d11 d3d10 d3d10core d3d10_1 d3d9 d3d8 dxgi ; do
            if [ -d "${WINEDIR}/lib64" ]; then
                [ -f "${WINEDIR}/lib/wine/i386-windows/${wine_build_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib/wine/i386-windows/${wine_build_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                [ -f "${WINEDIR}/lib64/wine/x86_64-windows/${wine_build_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib64/wine/x86_64-windows/${wine_build_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
            else
                [ -f "${WINEDIR}/lib/wine/i386-windows/${wine_build_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib/wine/i386-windows/${wine_build_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                [ -f "${WINEDIR}/lib/wine/x86_64-windows/${wine_build_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib/wine/x86_64-windows/${wine_build_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
            fi
        done

        for wine_vkd3d_dll in libvkd3d-1 libvkd3d-shader-1 ; do
            if [ -d "${WINEDIR}/lib64" ]; then
                [ -f "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                [ -f "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
            else
                [ -f "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                [ -f "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" ] && \
                    try_link "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
            fi
        done

        try_winedlloverride_update "d3d12,d3d11,d3d10,d3d10core,d3d10_1,d3d9,d3d8,dxgi=b"

        try_winedlloverride_update "openvr_api_dxvk,d3d12core=d"

        print_info "OpenGL API is used"

        notify-send -t 1500 -a "StartWine" "$(eval_gettext "OpenGL mode")"

        [ "${SW_USE_MANGOHUD}" == 1 ] && \
            export SW_RUN_MANGOHUD="mangohud --dlsym"

        if [ "${SW_USE_GALLIUM_HUD}" == 1 ]; then
            export GALLIUM_HUD_PERIOD=0.1
            export GALLIUM_HUD=".d.w320fps+.d.w320frametime+.d.w320cpu+.d.w320GPU-load+.d.w320memory-clock+.d.w320VRAM-usage+.d.w320temperature"
        fi

        [ -n "${SW_USE_LANG_MODE}" ] && \
            export LANG="${SW_USE_LANG_MODE}"

        cd "${SW_GAME_PATH}" || exit 0

        if [ "${SW_USE_VIRTUAL_DESKTOP}" == 1 ]; then
            ${SW_RUN_MANGOHUD} "${WINELOADER}" ${VDESKTOP} "$@" ${LAUNCH_PARAMETERS}
        else
            ${SW_RUN_MANGOHUD} "${WINELOADER}" "$@" ${LAUNCH_PARAMETERS}
        fi

        "${WINESERVER}" -w
        create_backup

    else

        try_fix_pfx

        sw_win_ver

        try_link_d3d_plugins

        if [ "${SW_USE_DXVK_GE}" == "1" ]; then
            if [ -d "${WINEDIR}/lib/wine/dxvk" ]; then
                for wine_dxvk_dll in openvr_api_dxvk d3d11 d3d10 d3d10core d3d10_1 d3d9 d3d8 dxgi ; do
                    if [ -d "${WINEDIR}/lib64" ]; then
                        [ -f "${WINEDIR}/lib/wine/dxvk/${wine_dxvk_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/wine/dxvk/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        [ -f "${WINEDIR}/lib64/wine/dxvk/${wine_dxvk_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib64/wine/dxvk/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    else
                        [ -f "${WINEDIR}/lib/wine/dxvk/i386-windows/${wine_dxvk_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/wine/dxvk/i386-windows/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        [ -f "${WINEDIR}/lib/wine/dxvk/x86_64-windows/${wine_dxvk_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/wine/dxvk/x86_64-windows/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    fi
                done
            else
                for wine_dxvk_dll in d3d11 d3d10 d3d10core d3d10_1 d3d9 d3d8 dxgi ; do
                    [ -f "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x32/${wine_dxvk_dll}.dll" ] && \
                        try_link "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x32/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                    [ -f "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x64/${wine_dxvk_dll}.dll" ] && \
                        try_link "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x64/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                done
            fi
        else
            for wine_dxvk_dll in d3d11 d3d10 d3d10core d3d10_1 d3d9 d3d8 dxgi ; do
                [ -f "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x32/${wine_dxvk_dll}.dll" ] && \
                    try_link "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x32/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                [ -f "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x64/${wine_dxvk_dll}.dll" ] && \
                    try_link "${START_WINE_PATH}/data/tools/vulkan/dxvk-${DXVK_VER}/x64/${wine_dxvk_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
            done
        fi

        if [ "${SW_USE_VKD3D_GE}" == "1" ]; then
            if [ -d "${WINEDIR}/lib/wine/vkd3d-proton" ]; then
                for wine_vkd3d_dll in d3d12 d3d12core ; do
                    if [ -d "${WINEDIR}/lib64" ]; then
                        try_link "${WINEDIR}/lib/wine/vkd3d-proton/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        try_link "${WINEDIR}/lib64/wine/vkd3d-proton/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    else
                        try_link "${WINEDIR}/lib/wine/vkd3d-proton/i386-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        try_link "${WINEDIR}/lib/wine/vkd3d-proton/x86_64-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    fi
                done

                for wine_vkd3d_dll in libvkd3d-1 libvkd3d-shader-1 ; do
                    if [ -d "${WINEDIR}/lib64" ]; then
                        [ -f "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        [ -f "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    else
                        [ -f "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        [ -f "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    fi
                done
            else
                if [ ! -f "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/d3d12core.dll" ]; then
                    try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/d3d12.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                    try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x64/d3d12.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/d3d12.dll" "${WINEPREFIX}/drive_c/windows/syswow64/d3d12core.dll"
                    try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x64/d3d12.dll" "${WINEPREFIX}/drive_c/windows/system32/d3d12core.dll"
                else
                    for wine_vkd3d_dll in d3d12 d3d12core ; do
                        try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x64/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    done
                fi

                for wine_vkd3d_dll in libvkd3d-1 libvkd3d-shader-1 ; do
                    if [ -d "${WINEDIR}/lib64" ]; then
                        [ -f "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        [ -f "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    else
                        [ -f "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                        [ -f "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" ] && \
                            try_link "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                    fi
                done
            fi
        else
            if [ ! -f "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/d3d12core.dll" ]; then
                try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/d3d12.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x64/d3d12.dll" "${WINEPREFIX}/drive_c/windows/system32"
                try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/d3d12.dll" "${WINEPREFIX}/drive_c/windows/syswow64/d3d12core.dll"
                try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x64/d3d12.dll" "${WINEPREFIX}/drive_c/windows/system32/d3d12core.dll"
            else
                for wine_vkd3d_dll in d3d12 d3d12core ; do
                    try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x86/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                    try_link "${START_WINE_PATH}/data/tools/vulkan/vkd3d-proton-${VKD3D_VER}/x64/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                done
            fi

            for wine_vkd3d_dll in libvkd3d-1 libvkd3d-shader-1 ; do
                if [ -d "${WINEDIR}/lib64" ]; then
                    [ -f "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                        try_link "${WINEDIR}/lib/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                    [ -f "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" ] && \
                        try_link "${WINEDIR}/lib64/vkd3d/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                else
                    [ -f "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" ] && \
                        try_link "${WINEDIR}/lib/vkd3d/i386-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                    [ -f "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" ] && \
                        try_link "${WINEDIR}/lib/vkd3d/x86_64-windows/${wine_vkd3d_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                fi
            done
        fi

        if [ -d "${WINEDIR}/lib/wine/icu" ]; then
            for wine_dll in icuin68 icuuc68 icudt68 ; do
                try_link "${WINEDIR}/lib/wine/icu/i386-windows/${wine_dll}.dll" "${WINEPREFIX}/drive_c/windows/syswow64"
                try_link "${WINEDIR}/lib/wine/icu/x86_64-windows/${wine_dll}.dll" "${WINEPREFIX}/drive_c/windows/system32"
                try_winedlloverride_update "icuin68,icuuc68,icudt68=n"
            done
        fi

        export SW_USE_GSTREAMER=0

        if [ "${SW_USE_GSTREAMER}" == 1 ]; then
            if [ -d "${WINEDIR}/lib64" ]; then
                export GST_PLUGIN_SYSTEM_PATH_1_0="${WINEDIR}/lib64/gstreamer-1.0:${WINEDIR}/lib/gstreamer-1.0"
            else
                export GST_PLUGIN_SYSTEM_PATH_1_0="${WINEDIR}/lib/x86_64-linux-gnu/gstreamer-1.0:${WINEDIR}/lib/i386-linux-gnu/gstreamer-1.0"
            fi
        fi

        try_winedlloverride_update "libvkd3d-1,libvkd3d-shader-1,d3d12,d3d12core,openvr_api_dxvk,d3d11,d3d10,d3d10core,d3d10_1,d3d9,d3d8,dxgi=n"

        if [ "${SW_USE_SHADER_CACHE}" == 1 ]; then
            try_create_dir "${START_WINE_PATH}/data/tmp/vulkan_shader_cache/${SW_GAME_NAME}"
            export DXVK_CONFIG_FILE="${START_WINE_PATH}/data/tools/utils/config/dxvk.conf"
            export DXVK_STATE_CACHE_PATH="${START_WINE_PATH}/data/tmp/vulkan_shader_cache/${SW_GAME_NAME}"
            export DXVK_SHADER_CACHE_PATH="${START_WINE_PATH}/data/tmp/vulkan_shader_cache/${SW_GAME_NAME}"
            export DXVK_STATE_CACHE=1
            export DXVK_SHADER_CACHE=1
            export DXVK_LOG_LEVEL="none"
            export DXVK_LOG_PATH="none"
            unset DXVK_DEBUG

            export VKD3D_SHADER_CACHE_PATH="${START_WINE_PATH}/data/tmp/vulkan_shader_cache/${SW_GAME_NAME}"
            export VKD3D_FEATURE_LEVEL="12_0"
            export VKD3D_SHADER_DEBUG="none"
            export VKD3D_DEBUG="none"
        else
            export DXVK_STATE_CACHE=0
            export DXVK_SHADER_CACHE=0
            unset DXVK_CONFIG_FILE DXVK_STATE_CACHE_PATH DXVK_SHADER_CACHE_PATH DXVK_LOG_LEVEL DXVK_LOG_PATH VKD3D_SHADER_CACHE_PATH VKD3D_FEATURE_LEVEL VKD3D_SHADER_DEBUG VKD3D_DEBUG DXVK_DEBUG
        fi

        print_info "Vulkan API is used"

        notify-send -t 1500 -a "StartWine" "$(eval_gettext "VULKAN mode")"

        if [ "${SW_USE_MESA_OVERLAY_HUD}" == 1 ]; then
            export VK_LAYER_MESA_OVERLAY_CONFIG="output_file=${START_WINE_PATH}/data/tmp/stats/${SW_GAME_NAME}.txt"
            export VK_LOADER_LAYERS_ENABLE="${VK_LOADER_LAYERS_ENABLE},VK_LAYER_MESA_overlay"
            export VK_INSTANCE_LAYERS="${VK_INSTANCE_LAYERS}:VK_LAYER_MESA_overlay"
        else
            export VK_LAYER_MESA_OVERLAY_CONFIG="no_display=1,output_file=${START_WINE_PATH}/data/tmp/stats/${SW_GAME_NAME}.txt"
            export VK_LOADER_LAYERS_ENABLE="${VK_LOADER_LAYERS_ENABLE},VK_LAYER_MESA_overlay"
            export VK_INSTANCE_LAYERS="${VK_INSTANCE_LAYERS}:VK_LAYER_MESA_overlay"
        fi

        [ -n "${SW_USE_LANG_MODE}" ] && \
            export LANG="${SW_USE_LANG_MODE}"

        cd "${SW_GAME_PATH}" || exit 0

        if [ "${SW_USE_VIRTUAL_DESKTOP}" == 1 ]; then
            "${WINELOADER}" ${VDESKTOP} "$@" ${LAUNCH_PARAMETERS}
        else
            "${WINELOADER}" "$@" ${LAUNCH_PARAMETERS}
        fi

        "${WINESERVER}" -w
        create_backup

    fi

}

###############################   CREATE SHORTCUT   ############################

CREATE_ICON () {

    SW_FORMAT_GAME_NAME="$(echo "${SW_GAME_NAME}" | tr -d "[:punct:]")"
    export SW_FORMAT_GAME_NAME

    export SW_APP_ICONS_DEFAULT="${START_WINE_PATH}/data/img/app_icons/default/${SW_FORMAT_GAME_NAME}_${SW_FORMAT_GAME_NAME}_x256.png"
    "$CRIER" --ico "${SW_GAME_EXE}" "${SW_APP_ICONS_DEFAULT}"

    [ ! -f "${SW_APP_ICONS_DEFAULT}" ] && \
        try_copy "${START_WINE_PATH}/data/img/gui_icons/unknown.png" "${SW_APP_ICONS_DEFAULT}"

}

CREATE_SHORTCUT () {

    if [ -f "${START_WINE_PATH}/data/pfx_backup/pfx_${SW_GAME_NAME}.iso" ]; then
        export SW_USE_PFX="pfx_${SW_GAME_NAME}"
        if [[ "${SW_USE_PFX}" != "pfx_default" && "${SW_USE_PFX}" != "pfx_StartWine" ]]; then
            crier=$("$CRIER" -q "$(eval_gettext "Restore prefix from backup?")")
            if [ "$(echo "$crier" | tail -1)" == "0" ]; then
                try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}"
                if unsquashfs -d "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" 2>/dev/null; then
                    try_copy "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}" "${START_WINE_PATH}/data/app_config"
                    try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}"
                fi
            fi
        fi
    fi

    CREATE_ICON

    echo "Exec=\"${SW_GAME_EXE}\"" > "${START_WINE_PATH}/Shortcuts/${SW_GAME_NAME}.swd"

}

WINEBOOT_CS () {

    crier=$("$CRIER" -q "$(eval_gettext "You have a backup of the default prefix with recommended libraries. Use it to create a new prefix?")")
    if [ "$(echo "$crier" | tail -1)" == "0" ]; then
        if unsquashfs -d "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" "${START_WINE_PATH}/data/pfx_backup/pfx_default.iso" 2>/dev/null; then
            [ "${REIN_PFX}" == 1 ] && \
                "$CRIER" -i "$(eval_gettext "Restore prefix completed successfully")"
        fi
    else
        "${WINELOADER}" wineboot || prefix_init_error
        "${WINESERVER}" -w

        [ "${REIN_PFX}" == 1 ] && \
            "$CRIER" -i "$(eval_gettext "Reinstall prefix completed successfully")"
    fi

}

ADD_SHORTCUT_TO_MENU () {

    SW_FORMAT_GAME_NAME="$(echo "${SW_GAME_NAME}" | tr -d "[:punct:]")"
    export SW_FORMAT_GAME_NAME
    SW_ICON_PATH="${START_WINE_PATH}/data/img/app_icons/default/${SW_FORMAT_GAME_NAME}_${SW_FORMAT_GAME_NAME}_x256.png"
    export SW_ICON_PATH

    if [ ! -f "${HOME}/.local/share/applications/${CUSTOME_GAME_NAME}.desktop" ]; then
        {
            echo "[Desktop Entry]"
            echo "Name=${CUSTOME_GAME_NAME}"
            echo "Comment=Play this game on StartWine"
            echo "Exec=env \"${SW_RUN_RUNIMAGE}\" \"${SW_GAME_EXE}\" --run"
            echo "Type=Application"
            echo "Categories=Game;"
            echo "Icon=${SW_ICON_PATH}"
        } > "${HOME}/.local/share/applications/${CUSTOME_GAME_NAME}.desktop"
        chmod +x "${HOME}/.local/share/applications/${CUSTOME_GAME_NAME}.desktop"
    fi

}

ADD_SHORTCUT_TO_DESKTOP () {

    SW_FORMAT_GAME_NAME="$(echo "${SW_GAME_NAME}" | tr -d "[:punct:]")"
    export SW_FORMAT_GAME_NAME
    SW_ICON_PATH="${START_WINE_PATH}/data/img/app_icons/default/${SW_FORMAT_GAME_NAME}_${SW_FORMAT_GAME_NAME}_x256.png"
    export SW_ICON_PATH

    if [ ! -f "${SW_DESKTOP_DIR}/${CUSTOME_GAME_NAME}.desktop" ]; then
        {
            echo "[Desktop Entry]"
            echo "Name=${CUSTOME_GAME_NAME}"
            echo "Comment=Play this game on StartWine"
            echo "Exec=env \"${SW_RUN_RUNIMAGE}\" \"${SW_GAME_EXE}\" --run"
            echo "Type=Application"
            echo "Categories=Game;"
            echo "Icon=${SW_ICON_PATH}"
        } > "${SW_DESKTOP_DIR}/${CUSTOME_GAME_NAME}.desktop"
        chmod +x "${SW_DESKTOP_DIR}/${CUSTOME_GAME_NAME}.desktop"
    fi

}

#################################   PREFIX TOOLS   #############################

REMOVE_PFX () {

    try_remove "${START_WINE_PATH}/data/pfx/pfx_${SW_GAME_NAME}"
    try_remove "${START_WINE_PATH}/Shortcuts/${SW_GAME_NAME}.swd"

    FORMAT_GAME_NAME="$(echo ${SW_GAME_NAME} | sed 's/_//g')"
    export FORMAT_GAME_NAME

    APP_ON_DESKTOP="$(ls "$START_WINE_PATH/data/img/app_icons/horizontal" | grep "${FORMAT_GAME_NAME}" | cut -d "_" -f3 | head -n1)"

    if [ "$APP_ON_DESKTOP" != "" ]; then
        try_remove "${SW_DESKTOP_DIR}/${APP_ON_DESKTOP}.desktop"
        try_remove "${HOME}/.local/share/applications/${APP_ON_DESKTOP}.desktop"
    fi

    if [ "${SW_GAME_NAME}" != "StartWine" ]; then
        try_remove "${SW_DESKTOP_DIR}/${SW_GAME_NAME}.desktop"
        try_remove "${HOME}/.local/share/applications/${SW_GAME_NAME}.desktop"
    fi

    notify-send -t 1500 -a "StartWine" "$(eval_gettext "Shortcut and prefix \${SW_GAME_NAME} removed")"

}

REINSTALL_PFX () {

    if [ "${SW_USE_PFX}" == "pfx_default" ]; then
        crier=$("$CRIER" -q "$(eval_gettext "Do you really want to reinstall the default prefix?")")
        if [ "$(echo "$crier" | tail -1)" == "0" ]; then
            try_remove "${START_WINE_PATH}/data/pfx/pfx_default"
            if unsquashfs -d "${START_WINE_PATH}/data/pfx/pfx_default" "${START_WINE_PATH}/data/pfx_backup/pfx_default.iso" 2>/dev/null; then
                "$CRIER" -i "$(eval_gettext "Restore completed successfully")"
            fi
        fi
    else
        crier=$("$CRIER" -q "$(eval_gettext "Do you really want to reinstall the prefix?")")
        if [ "$(echo "$crier" | tail -1)" == "0" ]; then
            if [ ! -f "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" ]; then
                crier=$("$CRIER" -q "$(eval_gettext "Remove old prefix?")")
                if [ "$(echo "$crier" | tail -1)" == "0" ]; then
                    try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}"
                    export REIN_PFX=1
                    WINEBOOT_CS
                fi
            else
                crier=$("$CRIER" -q "$(eval_gettext "Restore prefix from backup?")")
                if [ "$(echo "$crier" | tail -1)" == "0" ]; then
                    try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}"
                    if unsquashfs -d "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" 2>/dev/null; then
                        try_copy "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}" "${START_WINE_PATH}/data/app_config"

                        [ -f "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}" ] && \
                            try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}"

                        "$CRIER" -i "$(eval_gettext "Restore prefix completed successfully")"
                    fi
                else
                    crier=$("$CRIER" -q "$(eval_gettext "Remove old prefix?")")
                    if [ "$(echo "$crier" | tail -1)" == "0" ]; then
                        try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}"
                        export REIN_PFX=1
                        WINEBOOT_CS
                    fi
                fi
            fi
        fi
    fi

}

SW_PFX_BACKUP () {

    if [ "${SW_USE_PFX}" == "pfx_default" ]; then
        "$CRIER" -i "$(eval_gettext "You can not overwrite the default prefix backup")"
    else
        crier=$("$CRIER" -q "$(eval_gettext "Do you really want to backup the prefix?")")
        if [ "$(echo "$crier" | tail -1)" == "0" ]; then
            if [ -f "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" ]; then
                if [ -d "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" ]; then
                    crier=$("$CRIER" -q "$(eval_gettext "Overwrite old backup?")")
                    if [ "$(echo "$crier" | tail -1)" == "0" ]; then
                        try_copy "${START_WINE_PATH}/data/app_config/${SW_GAME_NAME}" "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}"
                        try_remove "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso"
                        if mksquashfs "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" -noappend -b 1M -comp zstd -Xcompression-level 1 2>/dev/null; then
                            try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}"
                            "$CRIER" -i "$(eval_gettext "Backup completed successfully")"
                        fi
                    fi
                else
                    "$CRIER" -i "$(eval_gettext "There is no application prefix, create one first")"
                fi
            else
                if [ -d "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" ]; then
                    try_copy "${START_WINE_PATH}/data/app_config/${SW_GAME_NAME}" "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}"
                    try_remove "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso"
                    if mksquashfs "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" -noappend -b 1M -comp zstd -Xcompression-level 1 2>/dev/null; then
                        try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}"
                        "$CRIER" -i "$(eval_gettext "Backup completed successfully")"
                    fi
                else
                    "$CRIER" -i "$(eval_gettext "There is no application prefix, create one first")"
                fi
            fi
        fi
    fi

}

SW_PFX_RESTORE () {

    if [ "${SW_USE_PFX}" == "pfx_default" ]; then
        crier=$("$CRIER" -q "$(eval_gettext "Do you really want to restore the default prefix?")")
        if [ "$(echo "$crier" | tail -1)" == "0" ]; then
            if [ -f "${START_WINE_PATH}/data/pfx_backup/pfx_default.iso" ]; then
                try_remove "${START_WINE_PATH}/data/pfx/pfx_default"
                if unsquashfs -d "${START_WINE_PATH}/data/pfx/pfx_default" "${START_WINE_PATH}/data/pfx_backup/pfx_default.iso" 2>/dev/null; then
                    "$CRIER" -i "$(eval_gettext "Restore completed successfully")"
                fi
            fi
        fi
    else
        crier=$("$CRIER" -q "$(eval_gettext "Do you really want to restore the prefix?")")
        if [ "$(echo "$crier" | tail -1)" == "0" ]; then
            if [ -f "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" ]; then
                try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}"
                if unsquashfs -d "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}" "${START_WINE_PATH}/data/pfx_backup/${SW_USE_PFX}.iso" 2>/dev/null; then
                    try_copy "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}" "${START_WINE_PATH}/data/app_config"
                    try_remove "${START_WINE_PATH}/data/pfx/${SW_USE_PFX}/${SW_GAME_NAME}"
                    "$CRIER" -i "$(eval_gettext "Restore completed successfully")"
                fi
            else
                "$CRIER" -i "$(eval_gettext "You do not have a backup create it first")"
            fi
        fi
    fi

}

SW_APP_SAVES_BACKUP () {

    crier=$("$CRIER" -q "$(eval_gettext "Create a backup copy of your saves?")")
    if [ "$(echo "$crier" | tail -1)" == "0" ]; then
        try_remove "${START_WINE_PATH}/data/app_saves/${USER}"
        if mksquashfs "${START_WINE_PATH}/data/app_saves" "${START_WINE_PATH}/data/pfx_backup/saves_backup.iso" -noappend -b 1M -comp zstd -Xcompression-level 1 2>/dev/null; then
            "$CRIER" -i "$(eval_gettext "The backup completed successfully")"
        fi
    fi

}

SW_APP_SAVES_RESTORE () {

    crier=$("$CRIER" -q "$(eval_gettext "Restore a backup copy of your saves?")")
    if [ "$(echo "$crier" | tail -1)" == "0" ]; then
        if [ -f "${START_WINE_PATH}/data/pfx_backup/saves_backup.iso" ]; then
            try_remove "${START_WINE_PATH}/data/app_saves"
            if unsquashfs -d "${START_WINE_PATH}/data/app_saves" "${START_WINE_PATH}/data/pfx_backup/saves_backup.iso" 2>/dev/null; then
                "$CRIER" -i "$(eval_gettext "The backup was successfully restored")"
            fi
        else
            "$CRIER" -i "$(eval_gettext "You do not have a backup copy of your saves")"
        fi
    fi

}

